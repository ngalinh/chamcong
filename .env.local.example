# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Face match threshold (0 = giống hệt, 1 = khác hẳn). 0.5 là baseline.
NEXT_PUBLIC_FACE_MATCH_THRESHOLD=0.5

# Danh sách email admin (Google accounts), phân cách bằng dấu phẩy.
# Các email này được tự động tạo admin khi login Google lần đầu.
ADMIN_EMAILS=admin1@gmail.com,admin2@gmail.com

# Office config nằm trong DB (bảng offices). Quản lý tại /admin/settings.

# Telegram bot — gửi thông báo khi có đơn xin nghỉ mới
# 1. Trong Telegram, chat với @BotFather → /newbot → đặt tên → lấy token
# 2. Chat với bot mới tạo, gửi bất kỳ tin nhắn nào (để "kích hoạt")
# 3. Lấy chat_id: chat với @userinfobot, nó sẽ trả về ID của bạn
# TELEGRAM_CHAT_IDS: nhiều admin → phân cách bằng dấu phẩy (vd "123,456")
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_IDS=
